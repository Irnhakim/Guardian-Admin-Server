# Guardian — Production Environment
# Copy this to .env and fill in your values

# Database
POSTGRES_PASSWORD=change_this_strong_password

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=change_this_jwt_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_refresh_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# URLs (update with your Cloudflare Tunnel domains)
FRONTEND_URL=https://guardian.yourdomain.com
NEXT_PUBLIC_API_URL=https://guardian-api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=https://guardian-api.yourdomain.com
